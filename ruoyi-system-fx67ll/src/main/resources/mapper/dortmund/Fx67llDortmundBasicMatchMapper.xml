    <sql id="selectFx67llDortmundBasicMatchWithJoinVo">
        select m.match_id,
               m.season_id,
               s.season_name as season_name,
               m.home_team_id,
               ht.team_name  as home_team_name,
               m.away_team_id,
               at.team_name  as away_team_name,
               m.match_time,
               m.match_venue,
               m.match_status,
               m.analysis_count,
               m.match_result,
               m.match_remark,
               m.user_id,
               m.create_by,
               m.create_time,
               m.update_by,
               m.update_time,
               m.del_flag
        from fx67ll_dortmund_match m
                 left join fx67ll_dortmund_season s on m.season_id = s.season_id
                 left join fx67ll_dortmund_team ht on m.home_team_id = ht.team_id
                 left join fx67ll_dortmund_team at
        on m.away_team_id = at.team_id
    </sql>

    <select id="selectFx67llDortmundBasicMatchList" parameterType="Fx67llDortmundBasicMatch"
            resultMap="Fx67llDortmundBasicMatchResult">
        <include refid="selectFx67llDortmundBasicMatchWithJoinVo"/>
        <where>
            <if test="seasonId != null ">and m.season_id = #{seasonId}</if>
            <if test="homeTeamId != null ">and m.home_team_id = #{homeTeamId}</if>
            <if test="awayTeamId != null ">and m.away_team_id = #{awayTeamId}</if>
            <if test="matchTime != null ">and m.match_time = #{matchTime}</if>
            <if test="matchVenue != null  and matchVenue != ''">and m.match_venue = #{matchVenue}</if>
            <if test="matchStatus != null  and matchStatus != ''">and m.match_status = #{matchStatus}</if>
            <if test="analysisCount != null ">and m.analysis_count = #{analysisCount}</if>
            <if test="matchResult != null  and matchResult != ''"> and match_result = #{matchResult}</if>
            <if test="matchRemark != null  and matchRemark != ''"> and match_remark = #{matchRemark}</if>
            <if test="delFlag != null  and delFlag != ''">and m.del_flag = #{delFlag}</if>
            <if test="userId != null ">and m.user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''">and m.create_by like concat('%', #{createBy}, '%')</if>
            <if test="beginCreateTime != null and endCreateTime != ''">and m.create_time between #{beginCreateTime} and
                #{endCreateTime}
            </if>
            <if test="updateBy != null  and updateBy != ''">and m.update_by like concat('%', #{updateBy}, '%')</if>
            <if test="beginUpdateTime != null and endUpdateTime != ''">and m.update_time between #{beginUpdateTime} and
                #{endUpdateTime}
            </if>
            <if test="beginMatchTime != null and endMatchTime != ''">and m.match_time between #{beginMatchTime} and
                #{endMatchTime}
            </if>
        </where>
        order by STR_TO_DATE(m.create_time, "%Y-%m-%d %H:%i:%s") desc
    </select>

    <select id="selectFx67llDortmundBasicMatchByMatchId" parameterType="Long"
            resultMap="Fx67llDortmundBasicMatchResult">
        <include refid="selectFx67llDortmundBasicMatchWithJoinVo"/>
        where m.match_id = #{matchId}
