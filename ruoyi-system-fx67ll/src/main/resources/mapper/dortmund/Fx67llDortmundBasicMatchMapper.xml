    <update id="updateFx67llDortmundBasicMatch" parameterType="Fx67llDortmundBasicMatch">
        update fx67ll_dortmund_match
        <trim prefix="SET" suffixOverrides=",">
            <if test="seasonId != null">season_id = #{seasonId},</if>
            <if test="homeTeamId != null">home_team_id = #{homeTeamId},</if>
