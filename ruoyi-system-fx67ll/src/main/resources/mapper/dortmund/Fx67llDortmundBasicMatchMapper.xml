<mapper namespace="com.ruoyi.fx67ll.dortmund.mapper.Fx67llDortmundBasicMatchMapper">

    <resultMap type="Fx67llDortmundBasicMatch" id="Fx67llDortmundBasicMatchResult">
        <result property="matchId" column="match_id"/>
        <result property="seasonId" column="season_id"/>
        <result property="seasonName" column="season_name"/>
