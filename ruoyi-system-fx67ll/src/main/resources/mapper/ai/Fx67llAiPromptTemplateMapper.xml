<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fx67ll.ai.mapper.Fx67llAiPromptTemplateMapper">

    <resultMap type="Fx67llAiPromptTemplate" id="Fx67llAiPromptTemplateResult">
        <result property="promptId" column="prompt_id"/>
        <result property="promptName" column="prompt_name"/>
        <result property="groupId" column="group_id"/>
        <result property="groupName" column="group_name"/>
        <result property="sceneId" column="scene_id"/>
        <result property="sceneName" column="scene_name"/>
        <result property="modelId" column="model_id"/>
        <result property="modelName" column="model_name"/>
        <result property="promptContent" column="prompt_content"/>
        <result property="promptVariableConfig" column="prompt_variable_config"/>
        <result property="promptCustomConfigParams" column="prompt_custom_config_params"/>
        <result property="promptStatus" column="prompt_status"/>
        <result property="promptRemark" column="prompt_remark"/>
        <result property="userId" column="user_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <!-- 可选的 SQL 片段，保留基础字段（若其他地方用到可以保留，但查询列表已重写，此处不强制修改） -->
    <sql id="selectFx67llAiPromptTemplateVo">
        select t.prompt_id,
               t.prompt_name,
               t.group_id,
               g.group_name as group_name,
               t.scene_id,
               s.scene_name as scene_name,
               t.model_id,
               m.model_name as model_name,
               t.prompt_content,
               t.prompt_variable_config,
               t.prompt_custom_config_params,
               t.prompt_status,
               t.prompt_remark,
               t.user_id,
               t.create_by,
               t.create_time,
               t.update_by,
               t.update_time,
               t.del_flag
        from fx67ll_ai_prompt_template t
                 left join fx67ll_ai_prompt_group g on t.group_id = g.group_id
                 left join fx67ll_ai_prompt_scene s on t.scene_id = s.scene_id
                 left join fx67ll_ai_prompt_model m on t.model_id = m.model_id
    </sql>

    <!-- 分页查询列表：左连接获取名称字段，条件参数化（去掉硬编码 del_flag） -->
    <select id="selectFx67llAiPromptTemplateList" parameterType="Fx67llAiPromptTemplate"
            resultMap="Fx67llAiPromptTemplateResult">
        <include refid="selectFx67llAiPromptTemplateVo"/>
        <where>
            <!-- 去掉硬编码的 t.del_flag = '0'，改为参数化判断，与第一个文件风格一致 -->
            <if test="delFlag != null and delFlag != ''">and t.del_flag = #{delFlag}</if>
            <if test="promptName != null and promptName != ''">and t.prompt_name like concat('%', #{promptName}, '%')
            </if>
            <if test="groupId != null">and t.group_id = #{groupId}</if>
            <if test="sceneId != null">and t.scene_id = #{sceneId}</if>
            <if test="modelId != null">and t.model_id = #{modelId}</if>
            <if test="promptContent != null and promptContent != ''">and t.prompt_content = #{promptContent}</if>
            <if test="promptVariableConfig != null and promptVariableConfig != ''">and t.prompt_variable_config =
                #{promptVariableConfig}
            </if>
            <if test="promptCustomConfigParams != null and promptCustomConfigParams != ''">and
                t.prompt_custom_config_params = #{promptCustomConfigParams}
            </if>
            <if test="promptStatus != null and promptStatus != ''">and t.prompt_status = #{promptStatus}</if>
            <if test="promptRemark != null and promptRemark != ''">and t.prompt_remark = #{promptRemark}</if>
            <if test="userId != null">and t.user_id = #{userId}</if>
            <if test="createBy != null and createBy != ''">and t.create_by like concat('%', #{createBy}, '%')</if>
            <if test="beginCreateTime != null and endCreateTime != ''">and t.create_time between #{beginCreateTime} and
                #{endCreateTime}
            </if>
            <if test="updateBy != null and updateBy != ''">and t.update_by like concat('%', #{updateBy}, '%')</if>
            <if test="beginUpdateTime != null and endUpdateTime != ''">and t.update_time between #{beginUpdateTime} and
                #{endUpdateTime}
            </if>
        </where>
        order by STR_TO_DATE(t.create_time, "%Y-%m-%d %H:%i:%s") desc
    </select>

    <!-- 根据主键查询单条记录：同样左连接获取名称字段（可选） -->
    <select id="selectFx67llAiPromptTemplateByPromptId" parameterType="Long" resultMap="Fx67llAiPromptTemplateResult">
        <include refid="selectFx67llAiPromptTemplateVo"/>
        where t.prompt_id = #{promptId}
    </select>

    <!-- 以下 insert、update、delete 保持不变，无需修改 -->
    <insert id="insertFx67llAiPromptTemplate" parameterType="Fx67llAiPromptTemplate" useGeneratedKeys="true"
            keyProperty="promptId">
        insert into fx67ll_ai_prompt_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="promptName != null and promptName != ''">prompt_name,</if>
            <if test="groupId != null">group_id,</if>
            <if test="sceneId != null">scene_id,</if>
            <if test="modelId != null">model_id,</if>
            <if test="promptContent != null and promptContent != ''">prompt_content,</if>
            <if test="promptVariableConfig != null">prompt_variable_config,</if>
            <if test="promptCustomConfigParams != null">prompt_custom_config_params,</if>
            <if test="promptStatus != null">prompt_status,</if>
            <if test="promptRemark != null">prompt_remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="userId != null">user_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="promptName != null and promptName != ''">#{promptName},</if>
            <if test="groupId != null">#{groupId},</if>
            <if test="sceneId != null">#{sceneId},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="promptContent != null and promptContent != ''">#{promptContent},</if>
            <if test="promptVariableConfig != null">#{promptVariableConfig},</if>
            <if test="promptCustomConfigParams != null">#{promptCustomConfigParams},</if>
            <if test="promptStatus != null">#{promptStatus},</if>
            <if test="promptRemark != null">#{promptRemark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="userId != null">#{userId},</if>
        </trim>
    </insert>

    <update id="updateFx67llAiPromptTemplate" parameterType="Fx67llAiPromptTemplate">
        update fx67ll_ai_prompt_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="promptName != null and promptName != ''">prompt_name = #{promptName},</if>
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="sceneId != null">scene_id = #{sceneId},</if>
            <if test="modelId != null">model_id = #{modelId},</if>
            <if test="promptContent != null and promptContent != ''">prompt_content = #{promptContent},</if>
            <if test="promptVariableConfig != null">prompt_variable_config = #{promptVariableConfig},</if>
            <if test="promptCustomConfigParams != null">prompt_custom_config_params = #{promptCustomConfigParams},</if>
            <if test="promptStatus != null">prompt_status = #{promptStatus},</if>
            <if test="promptRemark != null">prompt_remark = #{promptRemark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="userId != null">user_id = #{userId},</if>
        </trim>
        where prompt_id = #{promptId}
    </update>

    <delete id="deleteFx67llAiPromptTemplateByPromptId" parameterType="Long">
        delete
        from fx67ll_ai_prompt_template
        where prompt_id = #{promptId}
    </delete>

    <delete id="deleteFx67llAiPromptTemplateByPromptIds" parameterType="String">
        delete from fx67ll_ai_prompt_template where prompt_id in
        <foreach item="promptId" collection="array" open="(" separator="," close=")">
            #{promptId}
        </foreach>
    </delete>
</mapper>