<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fx67ll.ai.mapper.Fx67llAiRequestLogMapper">

    <resultMap type="Fx67llAiRequestLog" id="Fx67llAiRequestLogResult">
        <result property="requestLogId" column="request_log_id"/>
        <result property="promptId" column="prompt_id"/>
        <result property="promptName" column="prompt_name"/>
        <result property="groupId" column="group_id"/>
        <result property="groupName" column="group_name"/>
        <result property="sceneId" column="scene_id"/>
        <result property="sceneName" column="scene_name"/>
        <result property="modelId" column="model_id"/>
        <result property="modelName" column="model_name"/>
        <result property="requestContent" column="request_content"/>
        <result property="responseContent" column="response_content"/>
        <result property="promptTokens" column="prompt_tokens"/>
        <result property="completionTokens" column="completion_tokens"/>
        <result property="totalTokens" column="total_tokens"/>
        <result property="cost" column="cost"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="httpStatus" column="http_status"/>
        <result property="callStatus" column="call_status"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="callerIp" column="caller_ip"/>
        <result property="requestTime" column="request_time"/>
        <result property="userId" column="user_id"/>
        <result property="createBy" column="create_by"/>
    </resultMap>

    <sql id="selectFx67llAiRequestLogVo">
        SELECT log.request_log_id,
               log.prompt_id,
               pt.prompt_name AS promptName,
               log.group_id,
               pg.group_name  AS groupName,
               log.scene_id,
               ps.scene_name  AS sceneName,
               log.model_id,
               pm.model_name  AS modelName,
               log.request_content,
               log.response_content,
               log.prompt_tokens,
               log.completion_tokens,
               log.total_tokens,
               log.cost,
               log.duration_ms,
               log.http_status,
               log.call_status,
               log.error_msg,
               log.caller_ip,
               log.request_time,
               log.create_by,
               log.user_id
        FROM fx67ll_ai_request_log log
                 LEFT JOIN fx67ll_ai_prompt_template pt ON log.prompt_id = pt.prompt_id
                 LEFT JOIN fx67ll_ai_prompt_group pg ON log.group_id = pg.group_id
                 LEFT JOIN fx67ll_ai_prompt_scene ps ON log.scene_id = ps.scene_id
                 LEFT JOIN fx67ll_ai_prompt_model pm ON log.model_id = pm.model_id
    </sql>

    <select id="selectFx67llAiRequestLogList" parameterType="Fx67llAiRequestLog" resultMap="Fx67llAiRequestLogResult">
        <include refid="selectFx67llAiRequestLogVo"/>
        <where>
            <if test="promptId != null ">and log.prompt_id = #{promptId}</if>
            <if test="groupId != null ">and log.group_id = #{groupId}</if>
            <if test="sceneId != null ">and log.scene_id = #{sceneId}</if>
            <if test="modelId != null ">and log.model_id = #{modelId}</if>
            <if test="requestContent != null  and requestContent != ''">and log.request_content = #{requestContent}</if>
            <if test="responseContent != null  and responseContent != ''">and log.response_content =
                #{responseContent}
            </if>
            <if test="promptTokens != null ">and log.prompt_tokens = #{promptTokens}</if>
            <if test="completionTokens != null ">and log.completion_tokens = #{completionTokens}</if>
            <if test="totalTokens != null ">and log.total_tokens = #{totalTokens}</if>
            <if test="cost != null ">and log.cost = #{cost}</if>
            <if test="durationMs != null ">and log.duration_ms = #{durationMs}</if>
            <if test="httpStatus != null ">and log.http_status = #{httpStatus}</if>
            <if test="callStatus != null  and callStatus != ''">and log.call_status = #{callStatus}</if>
            <if test="errorMsg != null  and errorMsg != ''">and log.error_msg = #{errorMsg}</if>
            <if test="callerIp != null  and callerIp != ''">and log.caller_ip = #{callerIp}</if>
            <if test="userId != null ">and log.user_id = #{userId}</if>
            <if test="createBy != null  and createBy != ''">and log.create_by like concat('%', #{createBy}, '%')</if>
            <if test="beginRequestTime != null and endRequestTime != ''">and log.request_time between
                #{beginRequestTime} and #{endRequestTime}
            </if>
        </where>
        ORDER BY STR_TO_DATE(log.request_time, "%Y-%m-%d %H:%i:%s") DESC
    </select>

    <select id="selectFx67llAiRequestLogByRequestLogId" parameterType="Long" resultMap="Fx67llAiRequestLogResult">
        <include refid="selectFx67llAiRequestLogVo"/>
        WHERE log.request_log_id = #{requestLogId}
    </select>

    <insert id="insertFx67llAiRequestLog" parameterType="Fx67llAiRequestLog" useGeneratedKeys="true"
            keyProperty="requestLogId">
        insert into fx67ll_ai_request_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="promptId != null">prompt_id,</if>
            <if test="groupId != null">group_id,</if>
            <if test="sceneId != null">scene_id,</if>
            <if test="modelId != null">model_id,</if>
            <if test="requestContent != null">request_content,</if>
            <if test="responseContent != null">response_content,</if>
            <if test="promptTokens != null">prompt_tokens,</if>
            <if test="completionTokens != null">completion_tokens,</if>
            <if test="totalTokens != null">total_tokens,</if>
            <if test="cost != null">cost,</if>
            <if test="durationMs != null">duration_ms,</if>
            <if test="httpStatus != null">http_status,</if>
            <if test="callStatus != null">call_status,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="callerIp != null">caller_ip,</if>
            <if test="requestTime != null">request_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="userId != null">user_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="promptId != null">#{promptId},</if>
            <if test="groupId != null">#{groupId},</if>
            <if test="sceneId != null">#{sceneId},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="modelVendor != null and modelVendor != ''">#{modelVendor},</if>
            <if test="requestContent != null">#{requestContent},</if>
            <if test="responseContent != null">#{responseContent},</if>
            <if test="promptTokens != null">#{promptTokens},</if>
            <if test="completionTokens != null">#{completionTokens},</if>
            <if test="totalTokens != null">#{totalTokens},</if>
            <if test="cost != null">#{cost},</if>
            <if test="durationMs != null">#{durationMs},</if>
            <if test="httpStatus != null">#{httpStatus},</if>
            <if test="callStatus != null">#{callStatus},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="callerIp != null">#{callerIp},</if>
            <if test="requestTime != null">#{requestTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="userId != null">#{userId},</if>
        </trim>
    </insert>

    <update id="updateFx67llAiRequestLog" parameterType="Fx67llAiRequestLog">
        update fx67ll_ai_request_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="promptId != null">prompt_id = #{promptId},</if>
            <if test="groupId != null ">group_id = #{groupId},</if>
            <if test="sceneId != null">scene_id = #{sceneId},</if>
            <if test="modelId != null">model_id = #{modelId},</if>
            <if test="requestContent != null">request_content = #{requestContent},</if>
            <if test="responseContent != null">response_content = #{responseContent},</if>
            <if test="promptTokens != null">prompt_tokens = #{promptTokens},</if>
            <if test="completionTokens != null">completion_tokens = #{completionTokens},</if>
            <if test="totalTokens != null">total_tokens = #{totalTokens},</if>
            <if test="cost != null">cost = #{cost},</if>
            <if test="durationMs != null">duration_ms = #{durationMs},</if>
            <if test="httpStatus != null">http_status = #{httpStatus},</if>
            <if test="callStatus != null">call_status = #{callStatus},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="callerIp != null">caller_ip = #{callerIp},</if>
            <if test="requestTime != null">request_time = #{requestTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="userId != null">user_id = #{userId},</if>
        </trim>
        where request_log_id = #{requestLogId}
    </update>

    <delete id="deleteFx67llAiRequestLogByRequestLogId" parameterType="Long">
        delete
        from fx67ll_ai_request_log
        where request_log_id = #{requestLogId}
    </delete>

    <delete id="deleteFx67llAiRequestLogByRequestLogIds" parameterType="String">
        delete from fx67ll_ai_request_log where request_log_id in
        <foreach item="requestLogId" collection="array" open="(" separator="," close=")">
            #{requestLogId}
        </foreach>
    </delete>
</mapper>